# Fixtures
fixtures = [
    {"dt": "DocType", "filters": [["module", "in", [
        "Core SPC",
        "SPC Quality Management",
        "System Integration",
        "Operator Management",
        "Sensor Management",
        "Shop Floor Control",
        "SFC Manufacturing",
        "FDA Compliance",
        "Plant Equipment",
        "Real Time Monitoring"
    ]]]}
]

# List of modules in this app (required for migration)
