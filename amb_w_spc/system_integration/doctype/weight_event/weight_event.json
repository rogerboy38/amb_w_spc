{
  "doctype": "DocType",
  "name": "Weight Event",
  "module": "System Integration",
  "custom": 1,
  "istable": 0,
  "editable_grid": 1,
  "track_changes": 1,
  "engine": "InnoDB",
  "search_fields": "",
  "autoname": "naming_series:",
  "naming_rule": "By Naming Series",
  "sort_field": "modified",
  "sort_order": "DESC",
  "document_type": "Document",
  "read_only": 0,
  "fields": [
    {
      "doctype": "DocField",
      "name": "naming_series",
      "fieldtype": "Select",
      "label": "Naming Series",
      "options": "WE-.YYYY.-.MM.-.DD.-.#####",
      "reqd": 1,
      "hidden": 1
    },
    {
      "doctype": "DocField",
      "name": "event_timestamp",
      "fieldtype": "Datetime",
      "label": "Event Timestamp",
      "reqd": 1,
      "default": "now",
      "in_list_view": 1,
      "in_global_search": 1
    },
    {
      "doctype": "DocField",
      "name": "event_type",
      "fieldtype": "Select",
      "label": "Event Type",
      "options": "Weight Capture\nTare Reset\nCalibration\nZero Reset",
      "default": "Weight Capture",
      "in_list_view": 1
    },
    {
      "doctype": "DocField",
      "name": "device_id",
      "fieldtype": "Link",
      "label": "Device ID",
      "options": "Sensor Configuration",
      "reqd": 1,
      "in_list_view": 1,
      "in_global_search": 1
    },
    {
      "doctype": "DocField",
      "name": "barrel_serial",
      "fieldtype": "Data",
      "label": "Barrel Serial",
      "reqd": 1,
      "in_list_view": 1,
      "in_global_search": 1
    },
    {
      "doctype": "DocField",
      "name": "gross_weight",
      "fieldtype": "Float",
      "label": "Gross Weight (kg)",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "doctype": "DocField",
      "name": "tara_weight",
      "fieldtype": "Float",
      "label": "Tara Weight (kg)"
    },
    {
      "doctype": "DocField",
      "name": "net_weight",
      "fieldtype": "Float",
      "label": "Net Weight (kg)",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "doctype": "DocField",
      "name": "work_order",
      "fieldtype": "Link",
      "label": "Work Order",
      "options": "Work Order",
      "in_list_view": 1
    },
    {
      "doctype": "DocField",
      "name": "batch_no",
      "fieldtype": "Data",
      "label": "Batch Number",
      "in_list_view": 1,
      "in_global_search": 1
    },
    {
      "doctype": "DocField",
      "name": "quality_status",
      "fieldtype": "Select",
      "label": "Quality Status",
      "options": "Pass\nFail\nPending Review",
      "default": "Pass",
      "in_list_view": 1
    },
    {
      "doctype": "DocField",
      "name": "sync_status",
      "fieldtype": "Select",
      "label": "Sync Status",
      "options": "Pending\nSynced\nFailed\nSkipped",
      "default": "Pending",
      "in_list_view": 1
    },
    {
      "doctype": "DocField",
      "name": "raw_payload",
      "fieldtype": "Code",
      "label": "Raw Payload",
      "options": "JSON",
      "hidden": 1
    }
  ],
  "permissions": [
    {
      "doctype": "DocPerm",
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ],
  "description": "Weight Event Contract for IoT scale integration"
}
